  maven.javaLib("org.junit.jupiter", "junit-jupiter-api", "5.8.2"),
  junitConsoleDep,
  maven.javaLib("com.google.truth", "truth", truthVersion),
  maven.javaLib("com.google.truth.extensions", "truth-proto-extension", truthVersion),
]

scalaTestDeps = [
  ...testDeps,
  maven.javaLib("org.scalatest", "scalatest_${scalaVersion}", "3.2.15"),
]

base(basePath="base") {
  proto(basePath="proto") {
    schema = protobuf.schema(
      srcs = [
        "GrammarProto.proto",
        "TermGroupProto.proto",
      ]
    )

    javacode = protobuf.java(schema=proto.schema)
    javalib = java.library(
      srcs = proto.javacode.javaFiles,
      deps = [
        maven.javaLib("com.google.protobuf", "protobuf-java", protobufVersion),
      ],
    )
  }

  main = scala2.library(
    srcs = withBasePath("main/scala") {
      file.glob("**.scala")
    },
    deps = [proto.javalib],
  )

  test = scala2.library(
    srcs = withBasePath("test/scala") {
      file.glob("**.scala")
    },
    deps = [...scalaTestDeps, base.main],
  )
}

