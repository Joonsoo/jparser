mgroup2(basePath="mgroup2") {
  proto {
    schema = protobuf.schema(
      srcs = withBasePath("data/proto") { [
        "MilestoneGroupParserData.proto",
      ] },
      deps = [milestone2.proto.schema],
    )

    javacode = protobuf.java(schema=proto.schema)
    javalib = java.library(
      srcs = proto.javacode.javaFiles,
      deps = [milestone2.proto.javalib],
    )
  }

  data = scala2.library(
    srcs = withBasePath("data/scala") {
      file.glob("**.scala")
    },
    deps = [milestone2.data, proto.javalib],
  )

  gen = scala2.library(
    srcs = withBasePath("gen/scala") {
      file.glob("**.scala")
    },
    deps = [milestone2.gen, data],
  )

  parser = scala2.library(
    srcs = withBasePath("parser/scala") {
      file.glob("**.scala")
    },
    deps = [milestone2.parser, base.main, data, utils.main],
  )

  test = scala2.library(
    srcs = withBasePath("test/scala") {
      file.glob("**.scala")
    },
    resourceDirs = ["test/resources"],
    deps = [
      ...scalaTestDeps,
      data,
      gen,
      parser,
      naive.main,
      examples.metalang3,
      milestone2.gen,
      milestone2.parser,
      milestone2.test,
    ],
  )

  genCliJar = jar.executableUberJar(
    deps = [
      ktjvm.library(
        srcs = withBasePath("genCli/kotlin") {
          file.glob("**.kt")
        },
        deps = [gen, metalang.main],
      ),
    ],
    mainClass = "com.giyeok.jparser.mgroup2.GenCliKt",
  )

  class KotlinParser {
    srcsRoot: path
    astifier: path
    parserData: path
  }

  def genKtParser(
    cdgFile: path,
    astifierClassName: string,
    parserDataFileName: string = "mgroup2-parserdata.pb",
    trimParserData: bool = true,
  ): KotlinParser {
    let outDir = context.destDirectory()
    let srcsRoot = outDir / "srcs"
    let parserData = outDir / "data" / parserDataFileName
    // astifierClassName 의 마지막 컴포넌트 = 클래스명, 그 앞 = 패키지명.
    // 패키지 경로 / 클래스명.kt 는 CLI 가 srcs 안에 만들지만, KotlinParser 의 astifier 필드는
    // 그 정확한 파일 경로를 가리켜야 한다. 여기선 외부에서 알 수 없으므로 srcsRoot 자체로 둔다.
    // (소비측은 srcsRoot 디렉토리 전체를 컴파일하면 된다)
    file.createDirectory(srcsRoot)
    file.createDirectory(outDir / "data")
    if trimParserData {
      context.runCommand([
        "java",
        "-jar", genCliJar.jarFile,
        cdgFile,
        "-astifierClass", astifierClassName,
        "-parserdata", parserData,
        "-srcs", srcsRoot,
        "-trim",
      ])
    } else {
      context.runCommand([
        "java",
        "-jar", genCliJar.jarFile,
        cdgFile,
        "-astifierClass", astifierClassName,
        "-parserdata", parserData,
        "-srcs", srcsRoot,
      ])
    }
    return KotlinParser(
      srcsRoot = srcsRoot,
      astifier = srcsRoot,
      parserData = parserData,
    )
  }
}

mgroup3(basePath="mgroup3") {
  proto(basePath="schema/proto") {
    schema = protobuf.schema(
      srcs = [
        "Mgroup3ParserData.proto",
        "Mgroup3ParserResult.proto",
      ],
      deps = [base.proto.schema],
    )

    javacode = protobuf.java(schema=proto.schema)
    javalib = java.library(
      srcs = proto.javacode.javaFiles,
      deps = [base.proto.javalib],
    )
  }

  gen = ktjvm.library(
    srcs = withBasePath("gen/kotlin") {
      file.glob("**.kt")
    },
    deps = [
      proto.javalib,
      base.main,
      utils.main,
      maven.javaLib("com.google.guava", "guava", "33.4.8-jre"),
    ],
  )

  parser = ktjvm.library(
    srcs = withBasePath("parser/kotlin") {
      file.glob("**.kt")
    },
    deps = [
      proto.javalib,
      ktlib.main,
    ],
  )

  nativeParser = ktjvm.library(
    srcs = withBasePath("nativeParser/kotlin") {
      file.glob("**.kt")
    },
    deps = [
      proto.javalib,
      parser,
      ktlib.main,
      base.proto.javalib,
    ],
  )

  test = ktjvm.library(
    srcs = withBasePath("test/kotlin") {
      file.glob("**.kt")
    },
    resourceDirs = ["test/resources"],
    deps = [
      mgroup3.gen,
      mgroup3.parser,
      mgroup3.nativeParser,
      metalang.main,
      mgroup2.gen,
      mgroup2.parser,
      ktparser.main,
      kttestutils.main,
    ] + testDeps,
  )

  genCliJar = jar.executableUberJar(
    deps = [
      ktjvm.library(
        srcs = withBasePath("genCli/kotlin") {
          file.glob("**.kt")
        },
        deps = [gen, metalang.main],
      ),
    ],
    mainClass = "com.giyeok.jparser.mgroup3.GenCliKt",
  )

  class RustParser {
    // mgroup3 parser data 파일 경로
    parserData: path
    // AST data type 들을 serialize할 수 있는 protobuf 정의
    protoSchema: path
    // rustSrcsRoot 밑에는 mgroup3-native 에 dependency를 갖는,
    // rust parser crate가 생성되며, srcs, Cargo.toml, bulid.rs 가 있어야 함.
    // rust crate 에는 AST data class들이 포함되어 있고,
    // AST data class 들은 protobuf로 serialize할 수 있다.
    // 생성되는 rust crate는 input string을 받아 파싱을 수행하고,
    // 성공시엔 AST data type을, 실패시엔 에러 내용을 반환하는 기능을 포함한다.
    rustSrcsRoot: path
    // kotlinAdtRoot 에는 AST data type 구조를 정의한 코드가 포함되고,
    // protoSchema 에 정의된 protobuf Message 로부터 각 AST data type으로 변환하는 코드가 포함된다.
    kotlinAdtRoot: path
  }

  def genRustParser(
    cdgFile: path,
    parserDataFileName: string = "mgroup3-parserdata.pb",
    astProtoFileName: string = "ast-datatypes.proto",
    genKotlinBinding: bool = true,
  ): RustParser {
    let outDir = context.destDirectory()
    let dataFile = outDir / "data" / parserDataFileName
    let protoFile = outDir / "proto" / astProtoFileName
    let rust = outDir / "rust"
    let kotlin = outDir / "kotlin"

    file.createDirectory(outDir / "data")
    file.createDirectory(outDir / "proto")
    file.createDirectory(rust)
    file.createDirectory(kotlin)
    context.runCommand([
      "java",
      "-jar", genCliJar.jarFile,
      cdgFile,
      "-parserdata", dataFile,
      "-proto", protoFile,
      "-rust", rust,
      // TODO disable kotlin gen if genKotlinBinding is false
      "-kotlin", kotlin,
    ])
    return RustParser(
      parserData = dataFile,
      protoSchema = protoFile,
      rustSrcsRoot = rust,
      kotlinAdtRoot = kotlin
    )
  }

  def genFastParser(
    cdgFile: path,
    parserDataFileName: string = "mgroup3-parserdata.pb",
    astProtoFileName: string = "ast-datatypes.proto",
    // TODO target arch
  ): jvm.JvmLib {
    let rust = genRustParser(cdgFile, parserDataFileName, astProtoFileName)

    // TODO 생성된 rust -> so, dll, dylib 으로 컴파일하고, kotlin 코드 컴파일해서 반환
    return ktjvm.library(srcs = [])
  }
}

